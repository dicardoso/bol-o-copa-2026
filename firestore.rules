rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "diogomescardoso@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.email is string && data.points is number && data.noseCoins is number;
    }
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().points == 0;
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'noseCoins', 'preferences', 'security', 'pushSubscriptions']))
                    || isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
    }

    // --- Matches ---
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Bets (Match Predictions) ---
    function isValidBet(data) {
      return data.userId == request.auth.uid 
             && data.matchId is string 
             && data.predictedScoreA is number 
             && data.predictedScoreB is number;
    }
    match /bets/{betId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidBet(incoming())
                    && !get(/databases/$(database)/documents/matches/$(incoming().matchId)).data.finished;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidBet(incoming())
                    && incoming().matchId == existing().matchId
                    && !get(/databases/$(database)/documents/matches/$(existing().matchId)).data.finished;
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- ManuBets (Admin-defined casino options) ---
    match /manuBets/{manuBetId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['totalPool', 'poolByCategory', 'options']));
      allow delete: if isAdmin();
    }

    // --- UserManuBets (Casino placements) ---
    function isValidUserManuBet(data) {
      return data.userId == request.auth.uid 
             && data.amount is number 
             && data.amount > 0
             && data.status in ['pending', 'won', 'lost'];
    }
    match /userManuBets/{userBetId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidUserManuBet(incoming());
      allow update: if isAdmin(); 
      allow delete: if isSignedIn() && isOwner(resource.data.userId) && resource.data.status == 'pending';
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
